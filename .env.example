# Copie este arquivo para .env e preencha. NUNCA committe o .env.

# Steam Web API
# Obtenha em: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=YOUR_STEAM_API_KEY_HERE

# Sementes do BFS (CSV de SteamID 64)
# Comece com pelo menos 2 perfis públicos com CS2
SEED_STEAM_IDS=76561198XXXXXXXXX,76561198XXXXXXXXX

# Leetify (apenas necessário para fallback Selenium em scraping de partidas)
LEETIFY_USER=
LEETIFY_PASS=

# Configurações de coleta
MAX_PROFILES=3000
MAX_HOPS=2
RATE_LIMIT_STEAM_API=100  # requests/minuto, conservador
RATE_LIMIT_STEAM_MARKET=15  # requests/minuto, conservador
CACHE_TTL_HOURS=24
